# Copy to backend/.env and fill in real values. Never commit .env.

NODE_ENV=development
PORT=5000

# --- MongoDB Atlas (recommended) — choose ONE approach ---
#
# A) Full connection string (replace USER, PASSWORD, cluster host; database name before ?):
# MONGO_URI=mongodb+srv://USER:PASSWORD@cluster0.xxxxx.mongodb.net/kindloop?retryWrites=true&w=majority
#
# B) Separate variables (good if password has special characters):
# MONGO_ATLAS_USER=your_atlas_username
# MONGO_ATLAS_PASSWORD=your_atlas_password
# MONGO_ATLAS_HOST=cluster0.xxxxx.mongodb.net
# MONGO_ATLAS_DB=kindloop
#
# C) Legacy name (optional): MONGODB_URI=...
#
# Local MongoDB only (no Atlas): mongodb://127.0.0.1:27017/kindloop

# --- JWT (required) — use long random strings in production ---
JWT_SECRET=replace-with-a-long-random-secret-minimum-32-chars
JWT_REFRESH_SECRET=replace-with-another-long-random-secret-minimum-32-chars
JWT_EXPIRE=15m
JWT_REFRESH_EXPIRE=7d

# Must match the browser origin of the Vite app (localhost and 127.0.0.1 are both allowed in CORS)
FRONTEND_URL=http://localhost:5173

# Optional — payments: leave unset to disable Stripe routes until configured
# STRIPE_SECRET_KEY=sk_test_xxxxxxxx

# Optional: first-run admin seed
# ADMIN_SEED_EMAIL=admin@example.com
# ADMIN_SEED_PASSWORD=change-me-after-login

# AI microservice (Docker Compose sets this automatically)
# AI_MICROSERVICE_URL=http://localhost:8000
