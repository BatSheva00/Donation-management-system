{
  "watch": ["src"],
  "ext": "ts,json",
  "ignore": ["src/**/*.test.ts", "node_modules"],
  "exec": "node --inspect=0.0.0.0:9229 -r ts-node/register",
  "legacyWatch": true,
  "delay": 1000,
  "verbose": true,
  "signal": "SIGTERM",
  "env": {
    "NODE_ENV": "development"
  },
  "script": "src/server.ts"
}


