# Copy to frontend/.env — Vite reads VITE_* at dev/build time.

# Backend API (must include /api — matches Express mount)
VITE_API_URL=http://localhost:5000/api

# Socket.IO (no /api)
VITE_SOCKET_URL=http://localhost:5000

# Optional — Stripe donation UI
# VITE_STRIPE_PUBLISHABLE_KEY=pk_test_xxxxxxxx

# Optional — maps
# VITE_GOOGLE_MAPS_API_KEY=
